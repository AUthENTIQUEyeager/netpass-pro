generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Routeur {
  id           String     @id @default(uuid())
  nom          String
  site         String
  ip_address   String
  api_port     Int        @default(8728)
  api_user     String
  api_password String
  statut       String     @default("actif")
  created_at   DateTime   @default(now())
  updated_at   DateTime   @updatedAt
  tickets      Ticket[]
  commandes    Commande[]

  @@map("routeurs")
}

model Forfait {
  id           String     @id @default(uuid())
  nom          String
  duree_heures Int
  prix         Int
  vitesse      String
  description  String?
  wave_link    String?
  actif        Boolean    @default(true)
  created_at   DateTime   @default(now())
  updated_at   DateTime   @updatedAt
  commandes    Commande[]

  @@map("forfaits")
}

model Commande {
  id               String   @id @default(uuid())
  forfait_id       String
  routeur_id       String
  montant          Int
  statut           String   @default("en_attente")
  wave_ref         String?
  wave_checkout_id String?
  client_tel       String?
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt
  forfait          Forfait  @relation(fields: [forfait_id], references: [id])
  routeur          Routeur  @relation(fields: [routeur_id], references: [id])
  ticket           Ticket?

  @@map("commandes")
}

model Ticket {
  id              String   @id @default(uuid())
  commande_id     String   @unique
  routeur_id      String
  username        String   @unique
  password        String
  type            String   @default("online")
  statut          String   @default("actif")
  date_creation   DateTime @default(now())
  date_expiration DateTime
  commande        Commande @relation(fields: [commande_id], references: [id])
  routeur         Routeur  @relation(fields: [routeur_id], references: [id])

  @@map("tickets")
}

model Admin {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String
  nom        String
  role       String   @default("admin")
  created_at DateTime @default(now())

  @@map("admins")
}
